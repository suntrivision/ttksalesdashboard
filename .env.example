# Supabase project settings (Dashboard → Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — only for local upload script, never commit or expose in the app
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Storage bucket and file name (gzip keeps upload under free-tier 50 MB limit)
SUPABASE_STORAGE_BUCKET=sales-data
SUPABASE_DATA_FILE=combined_data.csv.gz

# Vercel only — URL of the Streamlit Cloud deployment
STREAMLIT_APP_URL=https://your-app-name.streamlit.app
